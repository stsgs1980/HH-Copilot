{
  "readme": "README.md",
  "sourceOfTruth": "extension/package.json",
  "checks": [
    {
      "name": "Extension source files",
      "source": "glob:extension/src/**/*.js",
      "exclude": [
        "test",
        "spec",
        "__mocks__"
      ],
      "readmePattern": "(\\d+) source files"
    },
    {
      "name": "Git commits",
      "source": "git:HEAD",
      "readmePattern": "(\\d+) commits",
      "tolerance": 5
    }
  ],
  "versionSync": {
    "source": "file:extension/package.json",
    "extractPattern": "\"version\":\\s*\"([\\d.]+)\"",
    "targets": [
      {
        "file": "README.md",
        "pattern": "(Version|Версия)\\*?\\*?:?\\s*[\\d.]+"
      }
    ]
  },
  "exclude": [
    "skills/",
    "docs/diagrams/",
    "docs/UNICODE_POLICY-v2.1.md",
    "docs/Z.ai-Sandbox-Guide.md",
    "docs/assets/",
    "docs/worklog.md",
    "docs/worklog-temp.md",
    "cascade/",
    ".ahg/",
    "extension/worklog.md",
    "extension/docs/UNICODE_POLICY.md",
    "extension/package-lock.json"
  ]
}
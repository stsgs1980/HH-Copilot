@startuml HH-Copilot Architecture v1.9.23
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultFontSize 12
skinparam defaultFontName Inter
skinparam ArrowColor #94A3B8
skinparam ArrowThickness 1.2
skinparam Padding 6
skinparam RoundCorner 8

skinparam package {
    BackgroundColor #F8FAFC
    BorderColor #94A3B8
    BorderThickness 1.5
    FontSize 14
    FontStyle bold
}

title HH-Copilot v1.9.23 — Full Architecture\nSource: github.com/stsgs1980/HH-Copilot

package "Chrome Browser (Manifest V3)" as Browser {

    package "MAIN World" #EFF6FF {
        component [page-world.js\n__hhVis() console helpers\nVisDiag data bridge\npostMessage listener] as PW #EFF6FF
    }

    package "Content Script (ISOLATED world)" #F0FDF4 {

        package "Entry + Routing" as CT_Entry #ECFDF5 {
            component [main.js\nBoot sequence + init] as MAIN
            component [main-page-handlers.js\nURL router + SPA handlers] as MPH
            component [main-resume-loader.js\nhh-ar-load-resume event] as MRL
            component [main-sync.js\nhh-ar-sync-resumes event] as MSYNC
        }

        package "Engine — Auto-Apply" as Engine #FEF3C7 {
            component [apply-orchestrator.js\napplyToVacancy / continueApply\napplyToAll] as EO
            component [apply-actions.js\nDOM: click, wait, submit] as EA
            component [apply-queue.js\nPersistent queue] as EQ
        }

        package "Parsers" as Parsers #D1FAE5 {
            component [vacancy-list.js\nSearch results parser] as VL
            component [vacancy-detail.js\nVacancy page parser] as VD
            component [vacancy-detail-skills.js\n3-strategy skill extraction] as VDS
            component [vacancy-diagnostic.js\nDiagnostics] as VDIAG
            component [negotiations.js\n**STUB — TODO**] as NEG #FEE2E2

            package "parsers/resume-detail/" as ResumeDetail #A7F3D0 {
                component [parse-resume.js\n13-field parser] as RDP
                component [parse-company-card.js] as RDPC
                component [parse-resume-sections.js] as RDPSEC
                component [parse-resume-education.js] as RDPEDU
                component [parse-resume-contacts.js] as RDPCON
                component [parse-resume-personal.js] as RDPPER
                component [parse-resume-conditions.js] as RDPCOND
                component [resume-detail-list-parser.js] as RDLIST
                component [diagnose.js + diagnose-*.js\nDOM diagnostics] as RDIAG
            }
        }
    }

    package "UI Layer — Sidebar + FAB" as UI_Layer #FFF7ED {

        package "UI Core" as UI_Core #FEF3C7 {
            component [panel/index.js\nSidebar orchestrator] as UIP
            component [panel/render.js\nContent rendering] as UIPR
            component [panel/events.js\nEvent binding] as UIPE
            component [panel/sidebar-events.js\nClick delegation] as UIPSE
            component [panel/helpers.js] as UIPH
            component [panel/panel-diagnostics.js] as UIPD
        }

        package "UI Components" as UI_Comp #FED7AA {
            component [fab.js\nFAB button + pulse] as FAB
            component [auth.js\nauth-check.js\nauth-detection.js\nauth-user.js] as AUTH
            component [state.js\npanelState object] as STATE
            component [styles.js + sidebar-css*.js\nShadow DOM CSS] as STY
        }

        package "UI Tabs" as UI_Tabs #FFEDD5 {
            component [overview.js\nKPI + timeline] as TOV
            component [vacancies.js\nScore cards + filter] as TVAC
            component [resumes/\nindex, render-my-resumes\nrender-resume-panel\nresume-helpers*.js\nsection-builders.js] as TRES
            component [negotiations.js] as TNEG
            component [settings.js] as TSET
            component [stats.js] as TSTA
        }

        package "HTML Templates" as UI_HTML #FFF1F2 {
            component [html/index.js\nshell.js\nhelpers.js + icons.js] as HIDX
            component [html/tabs/*.js\n6 tab templates] as HTABS
        }
    }

    package "Lib — Shared Business Logic" as Lib #F5F3FF {

        package "Match Scoring" as Scoring #EDE9FE {
            component [match-scorer.js\ncomputeMatchScore() 0-100] as MS_LIB
            component [match-scorer-skills.js\n0-40 pts skill overlap] as MSSK
            component [match-scorer-title.js\n0-30 pts title similarity] as MSTI
            component [match-scorer-salary.js\n0-15 pts salary range] as MSSA
            component [match-scorer-experience.js\n0-15 pts experience] as MSEX
        }

        package "Quality Analysis" as Quality #DDD6FE {
            component [resume-quality-analyzer.js\nFacade] as RQA
            component [quality-flags.js\nRed flags + recommendations] as QF
            component [quality-ats.js\nATS compatibility] as QAT
            component [quality-experience.js\nProgression detection] as QE
            component [quality-patterns.js\nAchievement verbs, metrics] as QP
            component [quality-date-helpers.js\nGap detection] as QD
        }

        package "Resume Fetch (6 strategies)" as ResumeFetch #E0E7FF {
            component [resume-fetch.js\nThin orchestrator] as RF
            component [resume-fetch-list.js\nResume list fetching] as RFL
            component [resume-fetch-resume.js\nSingle resume parsing] as RFR
            component [resume-fetch-experience.js\nStrategies 1-3 DOM] as RFEXP
            component [resume-fetch-strategy4-text.js\nText pattern parsing] as RF4
            component [resume-fetch-strategy5-scripts.js\nScript JSON orchestrator] as RF5S
            component [resume-fetch-strategy5-scanners.js\nJSON scanners] as RF5SC
            component [resume-fetch-strategy6-expand.js\nStrategy 6 orchestrator] as RF6E
            component [resume-fetch-strategy6-iframe.js\niframe sub-strategy] as RF6I
            component [resume-fetch-strategy6-urls.js\nURL discovery + fetch] as RF6U
            component [resume-fetch-strategy6-api.js\nApplicant API calls] as RF6A
            component [resume-fetch-education-languages.js] as RFEDU
            component [resume-fetch-parse.js] as RFPAR
            component [resume-fetch-json-utils.js] as RFJSON
            component [resume-fetch-vis-fallback.js\nVisibility diagnostics] as RFVIS
            component [resume-fetch-iframe-vis*.js\nvis, vis-dom, vis-adv] as RFIFR
            component [resume-fetch-list-vis*.js] as RFLVIS
            component [resume-fetch-resume-diag.js] as RFDIAG
            component [resume-fetch-resume-exp-orch.js] as RFEXPORCH
            component [resume-fetch-resume-page-vis.js] as RFPVIS
        }

        package "Lib Core" as LibCore #DBEAFE {
            component [anti-hallucination.js\nsafeGetText, Logger] as AH
            component [selectors.js\ndata-qa selectors] as SEL
            component [skill-dictionary.js\nSKILL_PATTERNS 50+] as SD
            component [skill-synonyms.js\nSynonym groups 50% weight] as SSYN
            component [derive-skills.js\nExperience -> skills] as DS
            component [vacancy-skills-collector.js\nShared skill collector] as VSC
            component [parse-experience.js\nExperience string parser] as PE
            component [timing.js\nGaussian delays, typing sim] as TIMING
            component [rate-limiter.js\nAdaptive rate limiting] as RL
            component [tour-engine.js + tour-tooltip.js\ntour-steps.js] as TOUR
        }

        package "Storage (chrome.storage.local)" as Storage #CFFAFE {
            component [storage.js — barrel] as STG
            component [storage-settings.js\nSettings + stats + daily reset] as STGS
            component [storage-queue.js\nResumes, blacklist, apply queue] as STGQ
            component [storage-vacancies.js\nVacancy details + scores] as STGV
        }

        package "Resume Constants" as ResumeConst #CFFAFE {
            component [resume-constants.js — barrel] as RC
            component [resume-constants-core.js] as RCC
            component [resume-constants-title.js] as RCT
            component [resume-constants-visibility.js] as RCV
        }
    }

    package "Background Service Worker" as BG_Pkg #FEE2E2 {
        component [background/index.js\nInstall, alarms, midnight reset\nMessage routing] as BGI
    }
}

